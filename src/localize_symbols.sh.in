#!/bin/bash
# Localize all non-dd_* symbols in a static archive so that only the
# extern "C" dd_* API functions are externally visible.
set -e
LIB="$1"
if [ "$(uname)" = "Darwin" ]; then
    EXPORTS=$(mktemp)
    nm -g "$LIB" | grep ' T _dd_' | awk '{print $3}' > "$EXPORTS"
    nmedit -s "$EXPORTS" "$LIB"
    rm "$EXPORTS"
elif [ "$(uname)" = "Linux" ]; then
    objcopy --localize-hidden "$LIB"
fi
