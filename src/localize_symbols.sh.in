#!/bin/bash
# Clean up a static archive so that only the extern "C" functions declared
# with `MULTIFLOATS_API` in multifloats_c.h remain globally visible. The
# keep-list is parsed straight out of the header (at CMake build time) via
# the bash code below, so adding/removing an API function in the header
# automatically flows through — no separate list to keep in sync.
#
# The old regex `dd(_[a-z]+)?$` would silently mislabel any future non-dd
# export (or any unrelated symbol that happened to end in `dd`); the
# header-derived keep-list is authoritative.
#
# Every other global is localized; local symbol names are then stripped.
# This logic is identical on Darwin and Linux by intent:
# CXX_VISIBILITY_PRESET + VISIBILITY_INLINES_HIDDEN already mark most C++
# inline copies hidden, but this script is the authoritative cut — an
# unexpected leak (e.g. a newly added static helper that accidentally
# escapes) gets localized here.
set -e
LIB="$1"
HEADER="@CMAKE_CURRENT_SOURCE_DIR@/multifloats_c.h"
EXPORTS=$(mktemp)
trap 'rm -f "$EXPORTS"' EXIT

# Build keep-list from every `MULTIFLOATS_API <type> <name>(` line anchored
# at column 0 in multifloats_c.h. Grep + awk gives us the symbol right
# before the `(`. On Darwin, Mach-O nm / nmedit both want the leading
# underscore stripped from the input list, so the list itself is plain
# C-identifier names on both platforms; the per-platform code below adjusts.
grep -oE "^MULTIFLOATS_API[^(]+\(" "$HEADER" \
    | awk '{print $NF}' | sed 's/($//' | sort -u > "$EXPORTS"

if [ ! -s "$EXPORTS" ]; then
    echo "localize_symbols.sh: no MULTIFLOATS_API symbols found in $HEADER" >&2
    exit 1
fi

case "$(uname)" in
  Darwin)
    # Mach-O nm lists symbols with a leading underscore; nmedit expects
    # the same mangling, so prefix the keep-list in a scratch file.
    DARWIN_EXPORTS=$(mktemp)
    trap 'rm -f "$EXPORTS" "$DARWIN_EXPORTS"' EXIT
    awk '{print "_" $0}' "$EXPORTS" > "$DARWIN_EXPORTS"
    nmedit -s "$DARWIN_EXPORTS" "$LIB"
    strip -x "$LIB"
    ;;
  Linux)
    # ELF nm lists symbols without a leading underscore; objcopy
    # --keep-global-symbols consumes the plain list.
    objcopy --keep-global-symbols="$EXPORTS" "$LIB"
    strip --strip-unneeded "$LIB"
    ;;
esac
