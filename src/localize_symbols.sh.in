#!/bin/bash
# Clean up a static archive so that only the extern "C" dd_* API
# functions are visible. Two steps:
#   1. Localize non-dd_* global symbols (nmedit/objcopy)
#   2. Strip local symbol names (strip -x) for a clean nm output
set -e
LIB="$1"
if [ "$(uname)" = "Darwin" ]; then
    EXPORTS=$(mktemp)
    nm -g "$LIB" | grep ' T _dd_' | awk '{print $3}' > "$EXPORTS"
    nmedit -s "$EXPORTS" "$LIB"
    rm "$EXPORTS"
    strip -x "$LIB"
elif [ "$(uname)" = "Linux" ]; then
    objcopy --localize-hidden "$LIB"
    strip --strip-unneeded "$LIB"
fi
